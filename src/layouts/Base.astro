---
import { ClientRouter } from 'astro:transitions';
interface Props {
  title: string;
  description?: string;
}
const { title, description = "Solar Singularity — a master's project on folklore, identity, and participatory design." } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
    <ClientRouter />
    <slot name="head" />
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --ink: #1a1a1a;
        --muted: #5a5a55;
        --rule: #c8c8c0;
        --bg: #fafaf8;
        --bg-warm: #f5f0e8;
        --link: #1a1a1a;
        --link-hover: #555;
        --font: 'Georgia', 'Times New Roman', serif;
        --sans: system-ui, -apple-system, sans-serif;
        --gap: 1.5rem;
      }

      html {
        background: #111;
        color: var(--ink);
        font-family: var(--font);
        font-size: 14px;
        line-height: 1.5;
      }

      body {
        min-height: 100vh;
        background: rgba(250, 250, 248, 0.9);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        display: flex;
        flex-direction: column;
      }

      /* ── View Transitions: stacking pages ── */
      @keyframes page-enter {
        from {
          transform: translateX(52px);
          opacity: 0;
        }
      }
      @keyframes page-exit {
        to {
          opacity: 0.12;
          transform: translateX(-20px) scale(0.984);
        }
      }

      ::view-transition-old(root) {
        animation: 480ms cubic-bezier(0.4, 0, 0.2, 1) forwards page-exit;
      }
      ::view-transition-new(root) {
        animation: 480ms cubic-bezier(0.4, 0, 0.2, 1) forwards page-enter;
      }

      /* ── Masthead ── */
      .masthead {
        border-bottom: 2px solid var(--ink);
        padding: 0.6rem var(--gap);
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1rem;
        flex-shrink: 0;
      }
      .site-name {
        font-family: var(--sans);
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.13em;
        text-transform: uppercase;
        text-decoration: none;
        color: var(--ink);
      }
      .masthead-sub {
        font-family: var(--sans);
        font-size: 0.6rem;
        color: var(--muted);
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }
      nav {
        display: flex;
        gap: 1.25rem;
      }
      nav a {
        font-family: var(--sans);
        font-size: 0.68rem;
        color: var(--muted);
        text-decoration: none;
        letter-spacing: 0.07em;
        text-transform: uppercase;
      }
      nav a:hover { color: var(--ink); }

      /* ── Page grid ── */
      .page-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
      }
      .page-grid--fill {
        flex: 1;
        align-items: stretch;
      }
      .col {
        padding: 1.1rem var(--gap);
        min-width: 0;
      }
      .col + .col {
        border-left: 1px solid var(--rule);
      }
      .col-label {
        font-family: var(--sans);
        font-size: 0.6rem;
        letter-spacing: 0.13em;
        text-transform: uppercase;
        color: var(--muted);
        border-bottom: 1px solid var(--rule);
        padding-bottom: 0.3rem;
        margin-bottom: 0.9rem;
      }

      /* ── Main ── */
      main {
        flex: 1;
        display: flex;
        flex-direction: column;
      }

      /* ── Footer ── */
      footer {
        border-top: 1px solid var(--rule);
        padding: 0.55rem var(--gap);
        display: flex;
        justify-content: space-between;
        flex-shrink: 0;
      }
      footer p {
        font-family: var(--sans);
        font-size: 0.6rem;
        color: var(--muted);
        letter-spacing: 0.07em;
        text-transform: uppercase;
      }

      /* ── Typography ── */
      h1 { font-size: 1.55rem; line-height: 1.18; font-weight: normal; margin-bottom: 0.5rem; }
      h2 { font-size: 1.1rem; font-weight: normal; line-height: 1.3; margin: 1.5rem 0 0.4rem; border-top: 1px solid var(--rule); padding-top: 0.6rem; }
      h3 {
        font-size: 0.7rem;
        font-weight: 700;
        font-family: var(--sans);
        letter-spacing: 0.1em;
        text-transform: uppercase;
        margin: 1.2rem 0 0.35rem;
        color: var(--muted);
      }
      p { margin-bottom: 0.85rem; }
      ul, ol { padding-left: 1.15rem; margin-bottom: 0.85rem; }
      li { margin-bottom: 0.15rem; }
      strong { font-weight: 600; }
      a { color: var(--link); }
      a:hover { color: var(--link-hover); }

      .prose img { max-width: 100%; height: auto; margin: 1.5rem 0; }

      /* ── Rule ── */
      hr { border: none; border-top: 1px solid var(--rule); margin: 1.5rem 0; }
    </style>
  </head>
  <body>
    <header class="masthead">
      <a class="site-name" href="/">Solar Singularity</a>
      <span class="masthead-sub">Ornament Research</span>
      <nav>
        <a href="/blog">Posts</a>
        <a href="/about">About</a>
        <a href="/minesweeper">Minesweeper</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>Solar Singularity &mdash; M. Luhouski</p>
      <p>Master's Research &mdash; 2026</p>
    </footer>
  </body>
</html>
