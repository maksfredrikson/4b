---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function slugify(id: string) {
  return id.toLowerCase().replace(/\s+/g, '-').replace(/[^\w-]/g, '');
}

function formatDate(d: Date) {
  return d.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' });
}

// Distribute posts across 3 columns
const col1 = posts.filter((_, i) => i % 3 === 0);
const col2 = posts.filter((_, i) => i % 3 === 1);
const col3 = posts.filter((_, i) => i % 3 === 2);
---
<Base title="Posts — Solar Singularity">
  <style>
    .blog-header {
      border-bottom: 2px solid var(--ink);
      padding: 0.75rem var(--gap);
      display: flex;
      align-items: baseline;
      gap: 1rem;
    }
    .blog-header h1 {
      font-family: var(--sans);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.13em;
      text-transform: uppercase;
      margin: 0;
    }
    .blog-header .post-count {
      font-family: var(--sans);
      font-size: 0.6rem;
      color: var(--muted);
    }

    .articles-grid {
      grid-template-columns: 1fr 1fr 1fr;
      align-items: start;
    }

    .article-card {
      padding-bottom: 1.4rem;
      margin-bottom: 1.4rem;
      border-bottom: 1px solid var(--rule);
    }
    .article-card:last-child {
      border-bottom: none;
      margin-bottom: 0;
    }
    .article-date {
      font-family: var(--sans);
      font-size: 0.6rem;
      color: var(--muted);
      letter-spacing: 0.07em;
      text-transform: uppercase;
      margin-bottom: 0.35rem;
    }
    .article-card h2 {
      font-size: 1rem;
      line-height: 1.25;
      font-weight: normal;
      margin: 0 0 0.5rem;
      border: none;
      padding: 0;
    }
    .article-card h2 a {
      text-decoration: none;
    }
    .article-card h2 a:hover {
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .article-desc {
      font-size: 0.85rem;
      line-height: 1.55;
      color: #2a2a2a;
      margin-bottom: 0.65rem;
    }
    .read-more {
      font-family: var(--sans);
      font-size: 0.65rem;
      color: var(--muted);
      text-decoration: none;
    }
    .read-more:hover { color: var(--ink); }
  </style>

  <div class="blog-header">
    <h1>Posts</h1>
    <span class="post-count">{posts.length} article{posts.length !== 1 ? 's' : ''}</span>
  </div>

  <div class="page-grid articles-grid">
    <div class="col">
      <p class="col-label">Column I</p>
      {col1.map(post => (
        <article class="article-card">
          <p class="article-date">{formatDate(post.data.date)}</p>
          <h2><a href={`/blog/${slugify(post.id)}`}>{post.data.title}</a></h2>
          {post.data.description && (
            <p class="article-desc">{post.data.description}</p>
          )}
          <a class="read-more" href={`/blog/${slugify(post.id)}`}>Read article &rarr;</a>
        </article>
      ))}
    </div>
    <div class="col">
      <p class="col-label">Column II</p>
      {col2.map(post => (
        <article class="article-card">
          <p class="article-date">{formatDate(post.data.date)}</p>
          <h2><a href={`/blog/${slugify(post.id)}`}>{post.data.title}</a></h2>
          {post.data.description && (
            <p class="article-desc">{post.data.description}</p>
          )}
          <a class="read-more" href={`/blog/${slugify(post.id)}`}>Read article &rarr;</a>
        </article>
      ))}
    </div>
    <div class="col">
      <p class="col-label">Column III</p>
      {col3.map(post => (
        <article class="article-card">
          <p class="article-date">{formatDate(post.data.date)}</p>
          <h2><a href={`/blog/${slugify(post.id)}`}>{post.data.title}</a></h2>
          {post.data.description && (
            <p class="article-desc">{post.data.description}</p>
          )}
          <a class="read-more" href={`/blog/${slugify(post.id)}`}>Read article &rarr;</a>
        </article>
      ))}
    </div>
  </div>
</Base>
